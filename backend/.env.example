DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=seu_usuario_db
DB_PASSWORD=sua_senha_db
DB_NAME=bd_cadpositivo

# JWT
SECRET_KEY=sua_chave_jwt_forte
ALGORITHM=HS256

# URL publica do backend (usada para gerar links de arquivos para consumo externo, ex: Power BI)
PUBLIC_BASE_URL=http://127.0.0.1:8000

# Power BI / Azure AD
PBI_TENANT_ID=00000000-0000-0000-0000-000000000000
PBI_CLIENT_ID=00000000-0000-0000-0000-000000000000
PBI_CLIENT_SECRET=seu_client_secret_do_app_registration
PBI_GROUP_ID=00000000-0000-0000-0000-000000000000
PBI_REPORT_ID=00000000-0000-0000-0000-000000000000
